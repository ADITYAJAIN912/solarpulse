# ── Database ──────────────────────────────────────────────────────────────────
# Local development (default, no value needed):
# DATABASE_URL=sqlite:///./solarpulse.db

# Production — Supabase PostgreSQL (get this from your Supabase project settings
# under Project Settings → Database → Connection string → URI):
DATABASE_URL=postgresql://postgres:<password>@<host>.supabase.co:5432/postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a random 32+ character secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-random-32-character-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AI (Groq) ─────────────────────────────────────────────────────────────────
# Get your key from https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (localhost is always allowed)
# Example: CORS_ORIGINS_RAW=https://solarpulse.vercel.app
CORS_ORIGINS_RAW=https://your-app.vercel.app

# ── Admin seed endpoint ───────────────────────────────────────────────────────
# Any random string — keep secret. Used to authorize POST /admin/seed.
SEED_TOKEN=your-seed-token-here

# ── Demo account (auto-created on startup if no users exist) ──────────────────
# Change these before deploying if you want different demo credentials.
DEMO_EMAIL=demo@solarpulse.io
DEMO_PASSWORD=demo2026
DEMO_PLANT_NAME=Jaisalmer Solar Alpha
DEMO_PLANT_LOCATION=Jaisalmer, Rajasthan, India
DEMO_PLANT_LATITUDE=26.9124
DEMO_PLANT_LONGITUDE=70.9130
DEMO_PLANT_CAPACITY_MW=50.0
